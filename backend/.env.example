# ═══════════════════════════════════
# ShiftEase — .env.example
# Copy to .env and fill all values
# ═══════════════════════════════════

PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/shiftease
JWT_SECRET=your_strong_secret_min_32_chars_change_this
ALLOWED_ORIGINS=http://localhost:3000,https://app.shiftease.in

# OTP + WhatsApp (Twilio)
TWILIO_SID=ACxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_auth_token
TWILIO_FROM=+1415XXXXXXX
TWILIO_WA_FROM=whatsapp:+14155238886

# Payments
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxx
RAZORPAY_KEY_SECRET=your_secret

# AI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# Maps
GOOGLE_MAPS_API_KEY=AIzaXXXXXXXXX

# Storage
CLOUDINARY_CLOUD_NAME=shiftease
CLOUDINARY_API_KEY=your_key
CLOUDINARY_API_SECRET=your_secret

# Firebase Push
FIREBASE_PROJECT_ID=shiftease-app
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@shiftease-app.iam.gserviceaccount.com
